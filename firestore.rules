rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Regular user profile/progress data — the student can read/write their own doc,
    // EXCEPT they can never touch premium/entitlement fields from here (see entitlements below).
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // PREMIUM STATUS lives here instead, in its own locked collection.
    // The student can READ their own entitlement (so the UI can show "Premium" badge),
    // but can NEVER write it. Only the server (Firebase Admin SDK, which ignores these
    // rules entirely) can grant or revoke premium — e.g. from a verified payment webhook.
    match /entitlements/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

  // NOTE: the old questionBank collection has been retired — quiz
    // question caching now lives in Supabase (see supabase/setup.sql),
    // to protect Firestore's quota. Firestore keeps only serious account
    // data: auth, profiles, entitlements.

    // CLASS / CONNECTION / CONSENT SYSTEM — all three collections below are
    // server-only (Admin SDK bypasses these rules entirely). This is
    // deliberate: who can see or create a class/connection depends on
    // ROLE and RELATIONSHIP, not just "is this your own document" — logic
    // that's easy to get subtly wrong in security-rule syntax. Centralizing
    // it in the API endpoints (create-class, request-connection,
    // respond-connection, list-connections) means there's exactly one
    // place this logic lives and gets reviewed, not two.
    match /classes/{classId} {
      allow read, write: if false;
    }
    match /connections/{connectionId} {
      allow read, write: if false;
    }
    match /compassIds/{compassId} {
      allow read, write: if false;
    }

    // Block access to anything else by default
